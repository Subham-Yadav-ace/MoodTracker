# ─── MindMap — Environment Variable Reference for AWS Deployment ──────────────
#
# Copy this file, fill in real values, and store them in:
#   • AWS ECS Task Definition → Environment Variables, OR
#   • AWS Systems Manager Parameter Store, OR
#   • AWS Secrets Manager (recommended for secrets)
#
# NEVER commit real values to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── SERVER ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Your frontend URL — used for CORS (e.g. CloudFront distribution or ALB URL)
CLIENT_URL=https://your-app.example.com

# ── MONGODB ──────────────────────────────────────────────────────────────────
# Use MongoDB Atlas for AWS deployments (recommended)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/mindmap
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/mindmap?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── HUGGINGFACE ──────────────────────────────────────────────────────────────
HF_API_KEY=

# ── FAST2SMS (Crisis SMS) ─────────────────────────────────────────────────────
FAST2SMS_API_KEY=

# ── SENDGRID (Weekly Reports) ─────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── FRONTEND BUILD ARGS (passed at docker build time, NOT runtime) ────────────
# These get baked into the React bundle — set them in your CI/CD pipeline
VITE_API_URL=https://your-api.example.com
VITE_GOOGLE_MAPS_API_KEY=
